{
  "name": "sales-agent-system",
  "version": "1.0.0",
  "description": "Autonomous AI Sales Agent System for D2C Brands",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx esbuild src/index.ts src/workers/index.ts --bundle --platform=node --target=node20 --outdir=dist --format=esm --external:pg-native --packages=external",
    "start": "node dist/index.js",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed-leads.ts",
    "worker": "tsx src/workers/index.ts",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "bullmq": "^5.34.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.0",
    "puppeteer": "^23.5.0",
    "resend": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.8.0",
    "@types/pg": "^8.11.10",
    "esbuild": "^0.27.4",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
